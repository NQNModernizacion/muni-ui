{
  "name": "@nqnmodernizacion/muni-ui",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "tokens",
    "styles",
    "tailwind-preset.js",
    "README.md"
  ],
  "prepare": "npm run build",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./tokens.css": "./tokens/tokens.css",
    "./styles.css": "./styles/styles.css",
    "./tailwind-preset": "./tailwind-preset.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:types",
    "build:types": "tsc -p tsconfig.types.json",
    "prepublishOnly": "npm run build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=18 <20",
    "react-dom": ">=18 <20",
    "react-hook-form": ">=7 <8",
    "react-toastify": ">=10 <12"
  },
  "dependencies": {
    "react-select": "^5.10.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
